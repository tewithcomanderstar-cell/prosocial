NEXT_PUBLIC_APP_URL=https://your-domain.com
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/facebook-auto-posting?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-mini
OPENAI_CONTENT_MODEL=gpt-5-mini
OPENAI_ANALYTICS_MODEL=gpt-5.2
OPENAI_LIGHT_MODEL=gpt-5-nano
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_LOGIN_CONFIG_ID=your-facebook-login-config-id
FACEBOOK_REDIRECT_URI=https://your-domain.com/api/facebook/oauth/callback
FACEBOOK_AUTH_REDIRECT_URI=https://your-domain.com/api/auth/facebook/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/google-drive/oauth/callback
GOOGLE_AUTH_REDIRECT_URI=https://your-domain.com/api/auth/google/callback
CRON_SECRET=replace-with-cron-secret
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token

# Storage cleanup / MongoDB Atlas quota guard
STORAGE_CLEANUP_ENABLED=true
STORAGE_CLEANUP_INTERVAL_HOURS=6
STORAGE_WARNING_THRESHOLD_PERCENT=85
STORAGE_CRITICAL_THRESHOLD_PERCENT=95
STORAGE_LIMIT_MB=512
AUTO_POST_LOG_RETENTION_DAYS=7
FAILED_JOB_RETENTION_DAYS=3
RAW_RESPONSE_RETENTION_DAYS=1
UNUSED_IMAGE_RETENTION_HOURS=24
PREVIEW_RETENTION_HOURS=24
BLOB_TEMP_RETENTION_HOURS=6
BLOB_PREVIEW_RETENTION_HOURS=24
BLOB_RAW_OPENAI_RETENTION_HOURS=24
BLOB_UNUSED_IMAGE_RETENTION_HOURS=24
