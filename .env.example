NEXT_PUBLIC_APP_URL=http://localhost:3002
MONGODB_URI=mongodb://127.0.0.1:27017/facebook-auto-posting
JWT_SECRET=replace-with-a-long-random-secret
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-mini
OPENAI_CONTENT_MODEL=gpt-5-mini
OPENAI_ANALYTICS_MODEL=gpt-5.2
OPENAI_LIGHT_MODEL=gpt-5-nano
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_LOGIN_CONFIG_ID=your-facebook-login-config-id
FACEBOOK_REDIRECT_URI=http://localhost:3002/api/facebook/oauth/callback
FACEBOOK_AUTH_REDIRECT_URI=http://localhost:3002/api/auth/facebook/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3002/api/google-drive/oauth/callback
GOOGLE_AUTH_REDIRECT_URI=http://localhost:3002/api/auth/google/callback
CRON_SECRET=replace-with-cron-secret

# Shopee Affiliate Auto Post
# Set SHOPEE_PROVIDER=mock to test the full auto-post pipeline without calling Shopee.
SHOPEE_PROVIDER=mock
SHOPEE_AUTH_MODE=affiliate_graphql
SHOPEE_AFFILIATE_API_URL=
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=
SHOPEE_AFFILIATE_ID=
SHOPEE_TRACKING_ID=
SHOPEE_AFFILIATE_BASE_URL=
SHOPEE_REGION=TH
SHOPEE_API_SECRET=

# Storage cleanup / MongoDB Atlas quota guard
STORAGE_CLEANUP_ENABLED=true
STORAGE_CLEANUP_INTERVAL_HOURS=6
STORAGE_WARNING_THRESHOLD_PERCENT=85
STORAGE_CRITICAL_THRESHOLD_PERCENT=95
STORAGE_LIMIT_MB=512
AUTO_POST_LOG_RETENTION_DAYS=7
FAILED_JOB_RETENTION_DAYS=3
RAW_RESPONSE_RETENTION_DAYS=1
UNUSED_IMAGE_RETENTION_HOURS=24
PREVIEW_RETENTION_HOURS=24
